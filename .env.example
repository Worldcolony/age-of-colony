TXLINE_JWT=your-session-jwt
TXLINE_API_TOKEN=your-long-lived-api-token
TXLINE_BASE_URL=https://txline.txodds.com
TXLINE_FORCE_IPV4=true
# Optional RPC override for read-only validateStatV2 simulations.
# TXLINE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# TXLINE_VALIDATION_TIMEOUT_SECONDS=30

# Phantom proves player identity by signing a message only: no transaction,
# payment, or SOL. Keep this secret stable across restarts (32+ bytes).
WALLET_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
# WALLET_AUTH_DOMAIN=your-age-of-colony-domain.example
# WALLET_AUTH_URI=https://your-age-of-colony-domain.example
WALLET_CHALLENGE_TTL_SECONDS=300
WALLET_SESSION_TTL_SECONDS=3600
WALLET_MAX_PENDING_CHALLENGES=4096
# WALLET_COOKIE_SECURE=true

# Optional: pre-filter fixture snapshots by competition.
# TXLINE_COMPETITION_ID=

# Required to start Age of Colony games.
# Without this key, games stop with an explicit DeepSeek/OpenRouter error.
# OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_TOKENS=1200
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_DELAY_SECONDS=0.5
OPENROUTER_INPUT_PRICE_PER_MILLION_USD=0.09
OPENROUTER_OUTPUT_PRICE_PER_MILLION_USD=0.18
COLONY_AGENT_MODE=auto
COLONY_AGENT_CALL_MODE=per_ant
COLONY_AGENT_MAX_CALLS_PER_GAME=20000
COLONY_AGENT_MAX_PARALLEL_ANT_CALLS=12
COLONY_AGENT_ANT_BATCH_SIZE=50

# Optional but recommended for Railway/admin persistence.
# Run supabase/aoc_bootstrap.sql in the existing Supabase project first.
AOC_SUPABASE_ENABLED=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
