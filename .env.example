TXLINE_JWT=your-session-jwt
TXLINE_API_TOKEN=your-long-lived-api-token
TXLINE_BASE_URL=https://txline.txodds.com

# Optional: pre-filter fixture snapshots by competition.
# TXLINE_COMPETITION_ID=

# Required to start Age of Colony games.
# Without this key, games stop with an explicit DeepSeek/OpenRouter error.
# OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_TOKENS=1200
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_DELAY_SECONDS=0.5
OPENROUTER_INPUT_PRICE_PER_MILLION_USD=0.09
OPENROUTER_OUTPUT_PRICE_PER_MILLION_USD=0.18
COLONY_AGENT_MODE=auto
COLONY_AGENT_CALL_MODE=per_ant
COLONY_AGENT_MAX_CALLS_PER_GAME=20000
COLONY_AGENT_MAX_PARALLEL_ANT_CALLS=12
COLONY_AGENT_ANT_BATCH_SIZE=50
